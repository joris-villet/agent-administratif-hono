    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.29",
    "ky": "^2.0.2",
    "langchain": "^1.5.3",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
