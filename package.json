{
  "module": "src/index.ts",
  "type": "module",
  "name": "agent-administratif-hono",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "set:telegram:dev": "tsx scripts/telegram/set-dev-webhook.ts",
    "set:telegram:prod": "tsx scripts/telegram/set-prod-webhook.ts",
